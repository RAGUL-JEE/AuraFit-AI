<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="AuraFit-AI Enterprise Automation Suite" parallel="tests" thread-count="2">
    
    <listeners>
        <listener class-name="listeners.TestListener" />
        <listener class-name="listeners.AnnotationTransformer" />
    </listeners>

    <test name="Authentication Tests">
        <classes>
            <class name="tests.authentication.AuthTests" />
        </classes>
    </test>

    <test name="Dashboard Tests">
        <classes>
            <class name="tests.dashboard.DashboardTests" />
        </classes>
    </test>

    <test name="Profile Tests">
        <classes>
            <class name="tests.profile.ProfileTests" />
        </classes>
    </test>

    <test name="Workout Tests">
        <classes>
            <class name="tests.workout.WorkoutTests" />
        </classes>
    </test>

    <test name="Favorites Tests">
        <classes>
            <class name="tests.favorites.FavoritesTests" />
        </classes>
    </test>

    <test name="Schedule Tests">
        <classes>
            <class name="tests.schedule.ScheduleTests" />
        </classes>
    </test>

    <test name="Progress Tests">
        <classes>
            <class name="tests.progress.ProgressTests" />
        </classes>
    </test>

    <test name="History Tests">
        <classes>
            <class name="tests.history.HistoryTests" />
        </classes>
    </test>

    <test name="Settings Tests">
        <classes>
            <class name="tests.settings.SettingsTests" />
        </classes>
    </test>
</suite>
